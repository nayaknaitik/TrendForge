# ─────────────────────────────────────────────────────
# TrendForge – Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true
APP_NAME=TrendForge
APP_VERSION=0.1.0

# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Database (PostgreSQL + pgvector) ────────────────
DATABASE_URL=postgresql+asyncpg://trendforge:CHANGE_ME_DB_PASSWORD@localhost:5432/trendforge
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_DEFAULT_TTL=300

# ── Auth (JWT) ──────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_64_HEX
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI Services ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_AI_PROVIDER=openai        # openai | anthropic
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Social Platform APIs ────────────────────────────
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
META_ACCESS_TOKEN=

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── CORS ────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── S3 / Object Storage (optional) ─────────────────
# S3_BUCKET=
# S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
